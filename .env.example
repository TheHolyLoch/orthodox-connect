# orthodox-connect/.env.example

ROOT_DOMAIN=orthodox-connect.localhost
PORTAL_DOMAIN=portal.orthodox-connect.localhost
CHAT_DOMAIN=chat.orthodox-connect.localhost
MEET_DOMAIN=meet.orthodox-connect.localhost
LIBRARY_DOMAIN=library.orthodox-connect.localhost
COMPOSE_PROJECT_NAME=orthodox_connect

XMPP_DOMAIN=xmpp.orthodox-connect.localhost
XMPP_ADMIN_JID=admin@xmpp.orthodox-connect.localhost
XMPP_MUC_DOMAIN=rooms.xmpp.orthodox-connect.localhost
XMPP_UPLOAD_DOMAIN=upload.xmpp.orthodox-connect.localhost
XMPP_REGISTRATION_ENABLED=false
XMPP_PROVISIONING_TOKEN=local_dev_xmpp_provisioning_token_change_me
XMPP_PROVISIONING_URL=http://prosody:5280/orthodox_provisioning/account

HTTP_PORT=8081
HTTPS_PORT=8443

CONVERSE_BOSH_URL=https://chat.orthodox-connect.localhost:8443/http-bind
CONVERSE_WEBSOCKET_URL=wss://chat.orthodox-connect.localhost:8443/xmpp-websocket

POSTGRES_DB=orthodox_connect
POSTGRES_USER=orthodox_connect
POSTGRES_PASSWORD=local_dev_postgres_password_change_me
POSTGRES_HOST=127.0.0.1
POSTGRES_CONTAINER_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_CONTAINER_PORT=5432
POSTGRES_BIND_ADDRESS=127.0.0.1
POSTGRES_HOST_PORT=5432

PORTAL_DATABASE_URL=
PORTAL_ADMIN_HOST=0.0.0.0
PORTAL_ADMIN_PORT=8000
PORTAL_DB_MIGRATION_ATTEMPTS=30
PORTAL_INVITE_TOKEN_BYTES=32
PORTAL_SECRET_KEY=local_dev_portal_secret_change_me
PORTAL_SESSION_TTL_SECONDS=28800
PORTAL_BOOTSTRAP_ADMIN_EMAIL=
PORTAL_BOOTSTRAP_ADMIN_DISPLAY_NAME=
PORTAL_BOOTSTRAP_ADMIN_PASSWORD=

JITSI_PUBLIC_URL=https://meet.orthodox-connect.localhost:8443
JITSI_ENABLE_AUTH=1
JITSI_ENABLE_GUESTS=0
JITSI_JWT_APP_ID=orthodox_connect_jitsi
JITSI_JWT_APP_SECRET=local_dev_jitsi_jwt_secret_change_me
JITSI_MEETING_CREATOR_ROLES=parish_admin,diocesan_admin,platform_admin,clergy_verified
JITSI_TOKEN_TTL_SECONDS=3600
JITSI_XMPP_DOMAIN=meet.jitsi

ACME_EMAIL=admin@example.invalid

SMTP_HOST=
SMTP_PORT=
SMTP_USERNAME=
SMTP_PASSWORD=

REDIS_PASSWORD=

BACKUP_ROOT=./backups
BACKUP_TIMESTAMP_FORMAT=%Y%m%dT%H%M%SZ
RESTORE_DRY_RUN=false
RESTORE_CONFIRM=
