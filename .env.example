# Orthodox Connect - Developed by dgm (dgm@tuta.com)
# orthodox-connect/.env.example

ROOT_DOMAIN=orthodox-connect.localhost
PORTAL_DOMAIN=portal.orthodox-connect.localhost
CHAT_DOMAIN=chat.orthodox-connect.localhost
MEET_DOMAIN=meet.orthodox-connect.localhost
LIBRARY_DOMAIN=library.orthodox-connect.localhost

XMPP_DOMAIN=xmpp.orthodox-connect.localhost
XMPP_ADMIN_JID=admin@xmpp.orthodox-connect.localhost
XMPP_MUC_DOMAIN=rooms.xmpp.orthodox-connect.localhost
XMPP_UPLOAD_DOMAIN=upload.xmpp.orthodox-connect.localhost
XMPP_REGISTRATION_ENABLED=false

CONVERSE_BOSH_URL=https://chat.orthodox-connect.localhost/http-bind
CONVERSE_WEBSOCKET_URL=wss://chat.orthodox-connect.localhost/xmpp-websocket

HTTP_PORT=
HTTPS_PORT=

POSTGRES_DB=orthodox_connect
POSTGRES_USER=orthodox_connect
POSTGRES_PASSWORD=replace_with_postgres_password
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

PORTAL_DATABASE_URL=postgresql://orthodox_connect:replace_with_postgres_password@postgres:5432/orthodox_connect
PORTAL_ADMIN_HOST=0.0.0.0
PORTAL_ADMIN_PORT=8000
PORTAL_INVITE_TOKEN_BYTES=32
PORTAL_SECRET_KEY=replace_with_portal_secret_key

JITSI_IMAGE_VERSION=stable
JITSI_PUBLIC_URL=https://meet.orthodox-connect.localhost
JITSI_ENABLE_AUTH=1
JITSI_ENABLE_GUESTS=0
JITSI_JWT_APP_ID=orthodox_connect_jitsi
JITSI_JWT_APP_SECRET=replace_with_jitsi_jwt_secret
JITSI_MEETING_CREATOR_ROLES=parish_admin,diocesan_admin,platform_admin,clergy_verified
JITSI_TOKEN_TTL_SECONDS=3600
JITSI_XMPP_DOMAIN=meet.jitsi
JITSI_XMPP_AUTH_DOMAIN=auth.meet.jitsi
JITSI_XMPP_GUEST_DOMAIN=guest.meet.jitsi
JITSI_XMPP_MUC_DOMAIN=muc.meet.jitsi
JITSI_XMPP_INTERNAL_MUC_DOMAIN=internal-muc.meet.jitsi
JITSI_JICOFO_AUTH_PASSWORD=replace_with_jicofo_password
JITSI_JVB_AUTH_USER=jvb
JITSI_JVB_AUTH_PASSWORD=replace_with_jvb_password
JITSI_JVB_BREWERY_MUC=jvbbrewery
JITSI_JVB_PORT=10000

ACME_EMAIL=admin@example.invalid

SMTP_HOST=
SMTP_PORT=
SMTP_USERNAME=
SMTP_PASSWORD=

REDIS_PASSWORD=

BACKUP_ROOT=./backups
RESTORE_CONFIRM=
